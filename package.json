{
  "name": "pemira-ikm-ui",
  "version": "0.1.0",
  "private": true,
  "description": "Sistem pelaporan pelanggaran PEMIRA IKM UI 2025 — monorepo frontend + backend",
  "scripts": {
    "dev": "cd pemira-frontend && npm run dev",
    "build": "cd pemira-frontend && npm run build",
