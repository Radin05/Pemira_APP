# Salin ke .env di VPS lalu isi. JANGAN commit .env berisi nilai asli.
# Dipakai oleh docker-compose.yml.

# Domain yang sudah diarahkan (A record) ke IP publik VPS ini.
# Caddy otomatis menerbitkan sertifikat HTTPS untuk domain ini.
DOMAIN=kppemirakemenkes.ac.id

# Database (dibuat otomatis oleh container postgres).
DB_NAME=pemira_app
DB_USERNAME=postgres
DB_PASSWORD=root

# Rahasia JWT — minimal 32 byte. Generate: openssl rand -base64 48
APP_JWT_SECRET=ganti-dengan-hasil-openssl-rand

# Kunci enkripsi identitas pelapor — TEPAT 32 karakter.
# ⚠️ JANGAN diubah setelah ada laporan tersimpan (data lama tak bisa didekripsi).
APP_ENCRYPTION_KEY=ubah-jadi-32-karakter-rahasia!!

# Akun ADMIN pertama — dibuat sekali saat boot pertama. Login lalu ganti
# password, dan boleh kosongkan dua baris ini setelahnya.
BOOTSTRAP_ADMIN_EMAIL=admin@poltekkesbandung.ac.id
BOOTSTRAP_ADMIN_PASSWORD=ganti-password-admin-kuat
